# Fichier d'environnement — Variables requises pour le déploiement
# Copiez ce fichier en .env.local et remplissez vos valeurs
# NE COMMITEZ JAMAIS .env.local sur GitHub

# ─── SUPABASE (Obligatoire) ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_publique
# Optionnel (pour les API routes qui nécessitent un accès complet)
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# ─── NEO4J AURA (Optionnel — Graphe généalogique) ────────────────────────────
NEO4J_URI=neo4j+s://votre-instance.databases.neo4j.io
NEO4J_USERNAME=votre_username
NEO4J_PASSWORD=votre_password
NEO4J_DATABASE=votre_database

# ─── IA (Optionnel — À configurer plus tard) ─────────────────────────────────
DEEPSEEK_API_KEY=votre_cle_deepseek
